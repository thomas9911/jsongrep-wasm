{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun run transpile && bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts",
    "jco:transpile": "bun run jco transpile ../target/wasm32-wasip2/release/jsongrep_wasm.wasm -o generated",
    "jco:types": "rm -rf generated && bun run jco types -o generated ../wit",
    "transpile": "bun run jco:types && bun run jco:transpile"
  },
  "dependencies": {
    "@bytecodealliance/jco": "^1.17.6",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest"
  }
}
